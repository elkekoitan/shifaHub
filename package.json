{
  "name": "shifahub",
  "version": "0.0.1",
  "private": true,
  "description": "ShifaHub - Butunsel Tedavi Yonetim Platformu",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:push": "npm run db:push --workspace=apps/api",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.0",
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{js,jsx,json,md,yml,yaml,css}": ["prettier --write"]
  }
}
