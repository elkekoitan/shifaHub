# ShifaHub Environment Variables
# Copy to .env and fill in actual values

# ===== Database =====
DATABASE_URL=postgresql://shifahub:shifahub_dev@localhost:5432/shifahub
REDIS_URL=redis://localhost:6379/0

# ===== MinIO (S3-Compatible) =====
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=shifahub-uploads

# ===== Qdrant (Vector DB) =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=shifahub_kulliyat

# ===== AI APIs =====
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ===== Messaging =====
EVOLUTION_API_URL=http://localhost:8080
EVO_API_KEY=
TELEGRAM_BOT_TOKEN=
NETGSM_USER=
NETGSM_PASS=
RESEND_API_KEY=

# ===== App Config =====
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ===== Next.js Public =====
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ===== Coolify (Production) =====
COOLIFY_TOKEN=
COOLIFY_WEBHOOK_STAGING=
COOLIFY_WEBHOOK_PRODUCTION=

# ===== Monitoring =====
SENTRY_DSN=
LOG_LEVEL=info
